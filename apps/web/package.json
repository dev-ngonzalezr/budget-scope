  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.3.4",
    "vitest": "2.1.8",
    "eslint": "9.17.0",
    "eslint-config-next": "15.1.3",
    "prettier": "3.4.2",
    "@eslint/eslintrc": "3.2.0"
